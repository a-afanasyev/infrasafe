# ==========================================
# InfraSafe Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env files with real secrets to git!

# ------------------------------------------
# Server Settings
# ------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=infrasafe
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ------------------------------------------
# JWT Authentication
# ------------------------------------------
# Generate secure secrets with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
# Optional: token expiration (defaults in code if not set)
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------
# 2FA (TOTP) Encryption
# ------------------------------------------
# Generate: openssl rand -base64 32
# Must be at least 32 characters of random data
TOTP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ------------------------------------------
# CORS (comma-separated origins)
# ------------------------------------------
# Required in production — server reads CORS_ORIGINS (plural).
# Do NOT use `*` in production; list exact origins.
CORS_ORIGINS=http://localhost:8088

# ------------------------------------------
# Security (production recommended)
# ------------------------------------------
# HELMET_CSP_ENABLED=true
# SECURE_COOKIES=true
# TRUST_PROXY=true
# SESSION_SECRET=CHANGE_ME
# BCRYPT_ROUNDS=12

# ------------------------------------------
# Rate Limiting (optional)
# ------------------------------------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------
# Swagger (optional)
# ------------------------------------------
# SWAGGER_ENABLED=true

# ------------------------------------------
# Monitoring (optional)
# ------------------------------------------
# HEALTH_CHECK_ENABLED=true
# PROMETHEUS_ENABLED=false
# GRAFANA_ENABLED=false

# ------------------------------------------
# Backup (optional)
# ------------------------------------------
# BACKUP_ENABLED=false
# BACKUP_SCHEDULE=0 2 * * *

# ------------------------------------------
# UK Integration (ENV-only secrets — required if uk_integration_enabled=true in DB)
# ------------------------------------------
UK_WEBHOOK_SECRET=CHANGE_ME_SHARED_SECRET_WITH_UK_BOT
UK_SERVICE_USER=CHANGE_ME_UK_SERVICE_ACCOUNT
UK_SERVICE_PASSWORD=CHANGE_ME_UK_SERVICE_PASSWORD
# Required in production to prevent SSRF via DNS rebinding
UK_API_ALLOWED_HOSTS=uk-bot-api.example.com
