# ==========================================
# InfraSafe Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env files with real secrets to git!

# ------------------------------------------
# Server Settings
# ------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=infrasafe
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ------------------------------------------
# JWT Authentication
# ------------------------------------------
# Generate secure secrets with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
# Optional: token expiration (defaults in code if not set)
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ------------------------------------------
# CORS (optional, comma-separated origins)
# ------------------------------------------
# CORS_ORIGIN=http://localhost:8080

# ------------------------------------------
# Security (production recommended)
# ------------------------------------------
# HELMET_CSP_ENABLED=true
# SECURE_COOKIES=true
# TRUST_PROXY=true
# SESSION_SECRET=CHANGE_ME
# BCRYPT_ROUNDS=12

# ------------------------------------------
# Rate Limiting (optional)
# ------------------------------------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------
# Swagger (optional)
# ------------------------------------------
# SWAGGER_ENABLED=true

# ------------------------------------------
# Monitoring (optional)
# ------------------------------------------
# HEALTH_CHECK_ENABLED=true
# PROMETHEUS_ENABLED=false
# GRAFANA_ENABLED=false

# ------------------------------------------
# Backup (optional)
# ------------------------------------------
# BACKUP_ENABLED=false
# BACKUP_SCHEDULE=0 2 * * *
