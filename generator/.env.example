# ==========================================
# InfraSafe Generator Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env files with real secrets to git!

# ------------------------------------------
# Generator Service Settings
# ------------------------------------------
PORT=8081

# ------------------------------------------
# API Connection
# ------------------------------------------
# URL of the InfraSafe API to send generated metrics to
API_BASE_URL=http://host.docker.internal:3000/api

# API credentials for authentication
API_USERNAME=CHANGE_ME
API_PASSWORD=CHANGE_ME

# ------------------------------------------
# Schedule (cron format)
# ------------------------------------------
# How often to generate and send metrics
GENERATOR_CRON=*/5 * * * *
