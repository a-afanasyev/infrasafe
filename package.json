{
  "name": "infrasafe",
  "version": "1.0.0",
  "description": "Система мониторинга зданий и контроллеров",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/",
    "test": "jest",
    "test:unit": "jest tests/jest/unit",
    "test:integration": "jest tests/jest/integration",
    "test:security": "jest tests/jest/security",
    "test:load": "bash tests/load/run-load-tests.sh",
    "test:smoke": "bash tests/smoke/run-smoke-tests.sh",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:smoke",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "monitoring",
    "buildings",
    "controllers",
    "metrics"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dompurify": "^3.2.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "axios": "^1.11.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/jest/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageDirectory": "tests/reports/coverage",
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest/setup.js"
    ]
  }
}
