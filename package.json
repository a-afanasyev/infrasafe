{
  "name": "infrasafe",
  "version": "1.0.1",
  "description": "Система мониторинга зданий и контроллеров",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/",
    "test": "jest --forceExit",
    "test:unit": "jest tests/jest/unit",
    "test:integration": "jest tests/jest/integration",
    "test:security": "jest tests/jest/security",
    "test:load": "bash tests/load/run-load-tests.sh",
    "test:smoke": "bash tests/smoke/run-smoke-tests.sh",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:smoke",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config tests/jest/e2e/jest.e2e.config.js --runInBand --testTimeout=15000"
  },
  "keywords": [
    "monitoring",
    "buildings",
    "controllers",
    "metrics",
    "iot",
    "smart-building",
    "infrastructure",
    "habitat-monitoring",
    "leaflet",
    "docker",
    "nodejs",
    "postgresql"
  ],
  "author": "InfraSafe Development Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/a-afanasyev/infrasafe.git"
  },
  "homepage": "https://github.com/a-afanasyev/infrasafe#readme",
  "bugs": {
    "url": "https://github.com/a-afanasyev/infrasafe/issues"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dompurify": "^3.2.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "axios": "^1.11.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/jest/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/jest/e2e/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageDirectory": "tests/reports/coverage",
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest/setup.js"
    ]
  }
}
