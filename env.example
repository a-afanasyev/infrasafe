# Настройки приложения
NODE_ENV=production
PORT=3000

# База данных PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=infrasafe
DB_USER=postgres
# ⚠️ SECURITY: Измените этот пароль для production!
# Сгенерируйте безопасный пароль: openssl rand -base64 32
DB_PASSWORD=your_secure_password_here

# JWT секретные ключи
# ⚠️ SECURITY: ОБЯЗАТЕЛЬНО измените эти значения для production!
# Сгенерируйте: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Настройки логирования
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Настройки CORS: список разрешённых origins через запятую.
# ВАЖНО: сервер читает CORS_ORIGINS (мн. число), используйте именно это имя.
# Для production укажите конкретные домены, не wildcard.
CORS_ORIGINS=http://localhost:8088,https://your-production-domain.com

# TOTP (2FA) ключ шифрования — сгенерируйте: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# UK Integration (ENV-only, обязательны при включении uk_integration_enabled=true в БД)
UK_WEBHOOK_SECRET=change_me_shared_secret
UK_SERVICE_USER=change_me_uk_service_account
UK_SERVICE_PASSWORD=change_me_uk_service_password
UK_API_ALLOWED_HOSTS=uk-bot-api.example.com

# Настройки безопасности
HELMET_CSP_ENABLED=true

# Настройки Swagger (отключить в продакшене)
SWAGGER_ENABLED=false

# Настройки мониторинга
HEALTH_CHECK_ENABLED=true