# Настройки приложения
NODE_ENV=production
PORT=3000

# База данных PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=infrasafe
DB_USER=postgres
# ⚠️ SECURITY: Измените этот пароль для production!
# Сгенерируйте безопасный пароль: openssl rand -base64 32
DB_PASSWORD=your_secure_password_here

# JWT секретные ключи
# ⚠️ SECURITY: ОБЯЗАТЕЛЬНО измените эти значения для production!
# Сгенерируйте: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Настройки логирования
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Настройки CORS (укажите домены для продакшена)
CORS_ORIGIN=*

# Настройки безопасности
HELMET_CSP_ENABLED=true

# Настройки Swagger (отключить в продакшене)
SWAGGER_ENABLED=false

# Настройки мониторинга
HEALTH_CHECK_ENABLED=true